<div class="w-11/12 mx-auto text-center bg-white">
		<div vg-for='i, _ := range c.Training.Blocks'>
			<comps:BlockForm :Block='&c.Training.Blocks[i]'></comps:BlockForm>
			<div class="inline-flex m-2">
				<button
					class="bg-sky-500 text-white py-2 px-4 rounded-l"
					@click='c.moveBlockUp(i, event)'
					><i class="fa-solid fa-arrow-up"></i>
				</button>
				<button
					class="bg-sky-500 text-white py-2 px-4"
					@click='c.moveBlockDown(i, event)'
					><i class="fa-solid fa-arrow-down"></i>
				</button>
				<button
					class="bg-sky-500 text-white py-2 px-4 rounded-r"
					@click='c.removeBlock(i, event)'
					><i class="fa-solid fa-trash-can"></i>
				</button>
			</div>
		</div>

		<div class="m-4 h-8 rounded-full bg-sky-500 flex items-center justify-center shadow"
			@click='c.addBlock()'>
			<div class="text-white text-xl">
				<div>Add block</div>
			</div>
		</div>

		<hr class="h-px border-0 bg-slate-500">

		<div class="pt-4 inline-flex text-center">
			<button
				class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded-l"
				@click='c.setManually = false'>
				Assign session
			</button>
			<button
				class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-bold py-2 px-4 rounded-r"
				@click='c.setManually = true'>
				Set manually
			</button>
		</div>

		<vg-template vg-if='!c.setManually' >
			<label for="session" class="block mt-4 text-base font-medium text-gray-900">Assign session to training</label>
		    <vgform:Select
				 id="session"
				 class="bg-gray-50 border border-gray-300 text-gray-900 text-sm
						rounded-lg focus:ring-blue-500 focus:border-blue-500
						block w-full p-2" 
				 :Value='vgform.StringPtr{&c.sessionOpt}'
				:Options='vgform.SliceOptions(c.options).Title()'>
			</vgform:Select>
		</vg-template>

		<vg-template vg-if='c.setManually' >
			<comps:SessionForm
				:Session='&c.session'
				:InvalidSession='&c.invalidSession'>
			</comps:SessionForm>
		</vg-template>
</div>
<script type="application/x-go">
import (
	"fmt"
	"strings"

	"github.com/Nesquiko/swimlogs/oapi-generator/oapiGen"
	"github.com/vugu/vugu/vgform"
)

type TrainingForm struct {
	Training *oapiGen.Training `vugu:"data"`
	Sessions []oapiGen.Session `vugu:"data"`

	session        oapiGen.Session
	invalidSession oapiGen.InvalidSession

	sessionOpt      string
	options         []string
	optionToSession map[string]*oapiGen.Session

	setManually bool
}

func (c *TrainingForm) Init(ctx vugu.InitCtx) {
	c.optionToSession = make(map[string]*oapiGen.Session)
	c.Training.Blocks = make([]oapiGen.Block, 1)
	sort.Slice(c.Training.Blocks, func(i, j int) bool {
		return c.Training.Blocks[i].Num < c.Training.Blocks[j].Num
	})
}

func (c *TrainingForm) Compute(ctx vugu.ComputeCtx) {
	if len(c.options) != 0 {
		return
	}
	for i := range c.Sessions {
		s := &c.Sessions[i]
		optName := fmt.Sprintf("%s %s %dmin", strings.Title(string(s.Day)), s.StartTime, s.DurationMin)
		c.optionToSession[optName] = s
		c.options = append(c.options, optName)
	}
}

func (c *TrainingForm) addBlock() {
	c.Training.Blocks = append(c.Training.Blocks, oapiGen.Block{})
	c.numberBlocks()
}

func (c *TrainingForm) moveBlockUp(blockIndex int, event vugu.DOMEvent) {
	if blockIndex == 0 {
		return
	}
	c.Training.Blocks[blockIndex].Num--
	c.Training.Blocks[blockIndex-1].Num++

	tmp := c.Training.Blocks[blockIndex]
	c.Training.Blocks[blockIndex] = c.Training.Blocks[blockIndex-1]
	c.Training.Blocks[blockIndex-1] = tmp
}

func (c *TrainingForm) moveBlockDown(blockIndex int, event vugu.DOMEvent) {
	if blockIndex == len(c.Training.Blocks)-1 {
		return
	}
	c.Training.Blocks[blockIndex].Num++
	c.Training.Blocks[blockIndex+1].Num--

	tmp := c.Training.Blocks[blockIndex]
	c.Training.Blocks[blockIndex] = c.Training.Blocks[blockIndex+1]
	c.Training.Blocks[blockIndex+1] = tmp
}

func (c *TrainingForm) removeBlock(blockIndex int, event vugu.DOMEvent) {
	c.Training.Blocks = append(c.Training.Blocks[:blockIndex], c.Training.Blocks[blockIndex+1:]...)
	c.numberBlocks()
}

func (c *TrainingForm) numberBlocks() {
	for i := range c.Training.Blocks {
		c.Training.Blocks[i].Num = i
	}
}
</script>
